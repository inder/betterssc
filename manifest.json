{
  "manifest_version": 3,
  "name": "BetterSSC",
  "version": "0.8.0",
  "description": "A Discord-style client for Substack Chat. Live updates, search, link previews, @mention notifications, send + reply + react.",
  "permissions": [
    "scripting",
    "storage",
    "tabs",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://substack.com/*",
    "https://*.substack.com/*",
    "https://*.s3.amazonaws.com/*",
    "https://substackcdn.com/*",
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.giphy.com/*",
    "https://media.giphy.com/*",
    "https://media0.giphy.com/*",
    "https://media1.giphy.com/*",
    "https://media2.giphy.com/*",
    "https://media3.giphy.com/*",
    "https://media4.giphy.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "referer_fix",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://substack.com/chat/*",
        "https://*.substack.com/chat/*",
        "https://substack.com/inbox/*",
        "https://*.substack.com/inbox/*"
      ],
      "js": ["network-hook.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://substack.com/chat/*",
        "https://*.substack.com/chat/*",
        "https://substack.com/inbox/*",
        "https://*.substack.com/inbox/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Open BetterSSC",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["app.html"],
      "matches": ["https://*.substack.com/*", "https://substack.com/*"]
    }
  ]
}
