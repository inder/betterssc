{
  "manifest_version": 3,
  "name": "BetterSSC",
  "version": "0.1.0",
  "description": "A Discord-style client for Substack Chat. Live updates, search, @mention notifications.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://substack.com/*",
    "https://*.substack.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://substack.com/*",
        "https://*.substack.com/*"
      ],
      "js": ["network-hook.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://substack.com/*",
        "https://*.substack.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Open BetterSSC",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["app.html"],
      "matches": ["https://*.substack.com/*", "https://substack.com/*"]
    }
  ]
}
